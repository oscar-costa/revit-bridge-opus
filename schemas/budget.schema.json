{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Revit OPUS Bridge Budget",
  "type": "object",
  "required": [
    "groups",
    "concepts"
  ],
  "properties": {
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "group_id",
          "code",
          "description",
          "unit"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "group_id": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "unit_price": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}